{
  "ConnectionStrings": {
    //"DefaultConnection": "Server=localhost;Database=ClinicOSDb;Integrated Security=True;TrustServerCertificate=True",
    "DefaultConnection": "Server=localhost;Database=Athul;Integrated Security=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "ClinicOS-SuperSecret-JWT-Key-For-Production-Use-2024!",
    "Issuer": "ClinicOS",
    "Audience": "ClinicOSUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "ApiKey": "YourApiKeyHere",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithCorrelationId"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
