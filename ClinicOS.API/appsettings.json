{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClinicOSDb;Integrated Security=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "ClinicOS-SuperSecret-JWT-Key-For-Production-Use-2024!",
    "Issuer": "ClinicOS",
    "Audience": "ClinicOSUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "ApiKey": "YourApiKeyHere",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/clinic-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
